{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem",
        "C:\\PARS"
      ]
    },
    "ruflo": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest"
      ]
    },
    "nanobanana": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@ycse/nanobanana-mcp"
      ]
    },
    "gdrive": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gdrive"
      ]
    },
    "instagram": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@mcpware/instagram-mcp"
      ]
    },
    "excel-mcp-server": {
      "type": "stdio",
      "command": "C:\\Users\\MSI-NB\\AppData\\Local\\Programs\\Python\\Python310\\Scripts\\excel-mcp-server.exe",
      "args": [
        "stdio"
      ]
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "C:\\PARS\\projects\\ARES"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@jpisnice/shadcn-ui-mcp-server"
      ]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}